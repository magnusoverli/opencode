#!/command/with-contenv bashio
# ==============================================================================
# OpenCode - Initialization Service (oneshot)
# Runs once at container startup to prepare the environment
# ==============================================================================

bashio::log.info "Initializing OpenCode..."

# Save addon version for the terminal banner
ADDON_VERSION=$(bashio::addon.version)
printf '%s\n' "${ADDON_VERSION}" > /data/.addon_version

# ==============================================================================
# Read configuration options
# ==============================================================================

CPU_MODE_CONFIG=$(bashio::config 'cpu_mode' || echo "auto")
OPENCODE_UPDATE_POLICY=$(bashio::config 'opencode_update_policy' || echo "latest")
INTERFACE_MODE=$(bashio::config 'interface_mode' 2>/dev/null || echo "terminal")
MCP_ENABLED=$(bashio::config 'mcp_enabled')
NATIVE_HA_MCP_ENABLED=$(bashio::config 'native_ha_mcp_enabled' 2>/dev/null || echo "false")
NATIVE_HA_MCP_API_ID=$(bashio::config 'native_ha_mcp_api_id' 2>/dev/null || echo "assist")
LSP_ENABLED=$(bashio::config 'lsp_enabled' || echo "true")
SCREENSHOT_ENABLED=$(bashio::config 'screenshot_enabled' || echo "false")
ADDON_ACCESS_ENABLED=$(bashio::config 'addon_access_enabled' || echo "false")
PPQ_PRIVATE_ENABLED=$(bashio::config 'ppq_private_enabled' || echo "false")

ACCESS_TOKEN=$(bashio::config 'access_token' || echo "")
PPQ_API_KEY=$(bashio::config 'ppq_api_key' || echo "")

if [ "${NATIVE_HA_MCP_API_ID}" = "null" ]; then
    NATIVE_HA_MCP_API_ID=""
fi

case "${OPENCODE_UPDATE_POLICY}" in
    latest|bundled)
        ;;
    *)
        bashio::log.warning "Unknown opencode_update_policy '${OPENCODE_UPDATE_POLICY}' - defaulting to latest"
        OPENCODE_UPDATE_POLICY="latest"
        ;;
esac

bashio::log.info "Configuration: INTERFACE_MODE=${INTERFACE_MODE} MCP=${MCP_ENABLED} NATIVE_HA_MCP=${NATIVE_HA_MCP_ENABLED} NATIVE_HA_MCP_API_ID=${NATIVE_HA_MCP_API_ID} LSP=${LSP_ENABLED} SCREENSHOT=${SCREENSHOT_ENABLED} PPQ_PRIVATE=${PPQ_PRIVATE_ENABLED} ADDON_ACCESS=${ADDON_ACCESS_ENABLED} CPU_MODE=${CPU_MODE_CONFIG} OPENCODE_UPDATE_POLICY=${OPENCODE_UPDATE_POLICY}"

# Set up persistent HOME and npm global prefix for OpenCode runtime updates.
export HOME="/data"
export XDG_DATA_HOME="/data/.local/share"
export XDG_CONFIG_HOME="/data/.config"
export NPM_CONFIG_PREFIX="/data/.npm-global"
OPENCODE_TMPDIR="/data/.cache/opencode-tmp"

if [ "${OPENCODE_UPDATE_POLICY}" = "latest" ]; then
    export PATH="${NPM_CONFIG_PREFIX}/bin:/usr/local/bin:/usr/bin:/bin:${PATH}"
else
    export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"
    export OPENCODE_DISABLE_AUTOUPDATE=true
fi

rm -rf "${OPENCODE_TMPDIR}"
mkdir -p /data/.local/share/opencode /data/.config/opencode "${NPM_CONFIG_PREFIX}" "${OPENCODE_TMPDIR}"
chmod 700 "${OPENCODE_TMPDIR}"
printf '%s\n' "${OPENCODE_UPDATE_POLICY}" > /data/.opencode_update_policy
printf '%s\n' "${INTERFACE_MODE}" > /data/.interface_mode

# ==============================================================================
# Process user-defined environment variables
# Reads env_vars from add-on config and writes a sourceable file at /data/.env_vars
# ==============================================================================

ENV_VARS_FILE="/data/.env_vars"

# Always start fresh to avoid stale variables from previous config
rm -f "${ENV_VARS_FILE}"

OPTIONS_FILE="/data/options.json"
ENV_VARS_COUNT=$(jq -r '.env_vars // [] | length' "${OPTIONS_FILE}")

# Reserved names that would break the add-on if overridden
ENV_VARS_RESERVED='"HOME","PATH","SUPERVISOR_TOKEN","HA_TOKEN","HA_NATIVE_MCP_API_ID","TMPDIR","XDG_DATA_HOME","XDG_CONFIG_HOME","NPM_CONFIG_PREFIX","npm_config_prefix","NODE_OPTIONS","OPENCODE_DISABLE_AUTOUPDATE","OPENCODE_UPDATE_POLICY","SHELL","USER","PWD"'

if [ "${ENV_VARS_COUNT}" -gt 0 ]; then
    bashio::log.info "Processing ${ENV_VARS_COUNT} user-defined environment variable(s)..."

    # Single jq pass emits all valid export lines (handles quoting via @sh,
    # multi-line values stay intact inside the quotes)
    jq -r "
        (.env_vars // [])[] |
        select(.name | test(\"^[A-Za-z_][A-Za-z0-9_]*\$\")) |
        select(.name | IN(${ENV_VARS_RESERVED}) | not) |
        \"export \(.name)=\(.value | tostring | @sh)\"
    " "${OPTIONS_FILE}" >> "${ENV_VARS_FILE}"

    # Second pass classifies names for logging only
    while IFS=$'\t' read -r STATUS VAR_NAME; do
        case "${STATUS}" in
            ok)
                bashio::log.info "  Set environment variable: ${VAR_NAME}"
                ;;
            invalid)
                bashio::log.warning "Skipping invalid environment variable name: '${VAR_NAME}'"
                bashio::log.warning "Names must start with a letter or underscore and contain only letters, digits, and underscores."
                ;;
            reserved)
                bashio::log.warning "Skipping reserved environment variable: '${VAR_NAME}'"
                bashio::log.warning "System variables cannot be overridden to prevent breaking the add-on."
                ;;
        esac
    done < <(jq -r "
        (.env_vars // [])[] | .name as \$n |
        if (\$n | test(\"^[A-Za-z_][A-Za-z0-9_]*\$\") | not) then
            \"invalid\t\(\$n | gsub(\"[\\n\\t]\"; \" \"))\"
        elif (\$n | IN(${ENV_VARS_RESERVED})) then
            \"reserved\t\(\$n)\"
        else
            \"ok\t\(\$n)\"
        end
    " "${OPTIONS_FILE}")

    chmod 600 "${ENV_VARS_FILE}"
    bashio::log.info "Environment variables written to ${ENV_VARS_FILE}"
else
    bashio::log.info "No user-defined environment variables configured"
fi

# Export system-managed runtime paths for all services and shell sessions.
printf 'export NPM_CONFIG_PREFIX=%q\n' "${NPM_CONFIG_PREFIX}" >> "${ENV_VARS_FILE}"
printf 'export OPENCODE_UPDATE_POLICY=%q\n' "${OPENCODE_UPDATE_POLICY}" >> "${ENV_VARS_FILE}"
printf 'export TMPDIR=%q\n' "${OPENCODE_TMPDIR}" >> "${ENV_VARS_FILE}"
if [ "${OPENCODE_UPDATE_POLICY}" = "latest" ]; then
    printf 'export PATH="%s/bin:/usr/local/bin:/usr/bin:/bin:${PATH}"\n' "${NPM_CONFIG_PREFIX}" >> "${ENV_VARS_FILE}"
else
    printf 'export PATH="/usr/local/bin:/usr/bin:/bin:${PATH}"\n' >> "${ENV_VARS_FILE}"
    printf 'export OPENCODE_DISABLE_AUTOUPDATE=true\n' >> "${ENV_VARS_FILE}"
fi
chmod 600 "${ENV_VARS_FILE}"

# ==============================================================================
# Expose configured serial devices to OpenCode and shell sessions
# Supervisor maps these devices into the container based on the device() schema.
# ==============================================================================

SERIAL_DEVICES_COUNT=$(bashio::config 'serial_devices | length' || echo "0")

if [ "${SERIAL_DEVICES_COUNT}" -gt 0 ]; then
    SERIAL_DEVICES=""
    for i in $(seq 0 $((SERIAL_DEVICES_COUNT - 1))); do
        SERIAL_DEVICE=$(bashio::config "serial_devices[${i}]")
        if [ -z "${SERIAL_DEVICES}" ]; then
            SERIAL_DEVICES="${SERIAL_DEVICE}"
        else
            SERIAL_DEVICES="${SERIAL_DEVICES}:${SERIAL_DEVICE}"
        fi
        bashio::log.info "Serial device configured: ${SERIAL_DEVICE}"
    done
    printf 'export OPENCODE_SERIAL_DEVICES=%q\n' "${SERIAL_DEVICES}" >> "${ENV_VARS_FILE}"
    chmod 600 "${ENV_VARS_FILE}"
else
    bashio::log.info "No serial devices configured"
fi

# ==============================================================================
# Export HA Core long-lived access token (for ESPHome ingress)
# Appended AFTER user env vars so it survives the rm -f above.
# ==============================================================================

if [ -n "${ACCESS_TOKEN}" ]; then
    printf 'export HA_ACCESS_TOKEN=%q\n' "${ACCESS_TOKEN}" >> "${ENV_VARS_FILE}"
    chmod 600 "${ENV_VARS_FILE}"
    bashio::log.info "HA Core access token configured (for ESPHome ingress)"
else
    bashio::log.info "No HA Core access token configured (ESPHome tools may not work)"
fi

# ==============================================================================
# Export PPQ API key for the internal private-mode proxy
# ==============================================================================

PPQ_API_KEY_CONFIGURED=false

if bashio::var.true "${PPQ_PRIVATE_ENABLED}"; then
    if [ -n "${PPQ_API_KEY}" ]; then
        printf 'export PPQ_API_KEY=%q\n' "${PPQ_API_KEY}" >> "${ENV_VARS_FILE}"
        chmod 600 "${ENV_VARS_FILE}"
        bashio::log.info "PPQ private mode enabled; API key configured"
        PPQ_API_KEY_CONFIGURED=true
    elif [ -f "${ENV_VARS_FILE}" ] && grep -qE '^export PPQ_API_KEY=' "${ENV_VARS_FILE}"; then
        bashio::log.info "PPQ private mode enabled; API key configured via env_vars"
        PPQ_API_KEY_CONFIGURED=true
    else
        bashio::log.warning "PPQ private mode is enabled, but no PPQ API key is configured"
        bashio::log.warning "The PPQ proxy and OpenCode provider will stay inactive until a key is added"
    fi
else
    bashio::log.info "PPQ private mode disabled"
fi

# ==============================================================================
# Add-on development access acknowledgement
# ==============================================================================

printf '%s\n' "${ADDON_ACCESS_ENABLED}" > /data/.addon_access_enabled

if bashio::var.true "${ADDON_ACCESS_ENABLED}"; then
    printf 'export OPENCODE_ADDON_ACCESS_ENABLED=true\n' >> "${ENV_VARS_FILE}"
    chmod 600 "${ENV_VARS_FILE}"
    bashio::log.warning "Add-on folder access is enabled. OpenCode can work with /addons and /addon_configs."
    bashio::log.warning "These folders may contain sensitive add-on configuration and should be edited carefully."
else
    printf 'export OPENCODE_ADDON_ACCESS_ENABLED=false\n' >> "${ENV_VARS_FILE}"
    chmod 600 "${ENV_VARS_FILE}"
    bashio::log.info "Add-on folder access guidance disabled. Mounted add-on folders are not advertised in the terminal."
fi

# ==============================================================================
# Auto-configure zigporter CLI credentials
# zigporter needs HA_URL + HA_TOKEN to talk to Home Assistant.
# Inside the Supervisor environment, http://supervisor/core proxies to HA Core
# and SUPERVISOR_TOKEN is a valid Bearer token — same mechanism as hab.
# HA_TOKEN is exported at runtime by the services that need it, not persisted
# into /data/.env_vars.
# ==============================================================================

printf 'export HA_URL=http://supervisor/core\n' >> "${ENV_VARS_FILE}"
printf 'export HA_VERIFY_SSL=false\n' >> "${ENV_VARS_FILE}"

# Z2M configuration — auto-discover or use manual override
# If the user has set z2m_url in the config, use that (manual override).
# Otherwise, try to auto-discover Z2M via the Supervisor API (same pattern as ESPHome).
Z2M_URL_CONFIG=$(bashio::config 'z2m_url' || echo "")
Z2M_TOPIC_CONFIG=$(bashio::config 'z2m_mqtt_topic' || echo "")

DISCOVER_Z2M_FLAG="true"
if [ -n "${Z2M_URL_CONFIG}" ]; then
    case "${Z2M_URL_CONFIG}" in
        http://*|https://*)
            Z2M_URL="${Z2M_URL_CONFIG}"
            ;;
        *)
            Z2M_URL="http://${Z2M_URL_CONFIG}"
            bashio::log.info "zigporter Z2M URL missing scheme; defaulting to ${Z2M_URL}"
            ;;
    esac
    printf 'export Z2M_URL=%q\n' "${Z2M_URL}" >> "${ENV_VARS_FILE}"
    bashio::log.info "zigporter Z2M URL configured (manual): ${Z2M_URL}"
    if [ -n "${Z2M_TOPIC_CONFIG}" ]; then
        printf 'export Z2M_MQTT_TOPIC=%q\n' "${Z2M_TOPIC_CONFIG}" >> "${ENV_VARS_FILE}"
    fi
    DISCOVER_Z2M_FLAG="false"
fi

chmod 600 "${ENV_VARS_FILE}"
bashio::log.info "zigporter credentials configured (HA via Supervisor proxy)"

# ==============================================================================
# Export screenshot_enabled flag for the MCP server
# ==============================================================================

if [ "${SCREENSHOT_ENABLED}" = "true" ]; then
    printf 'export SCREENSHOT_ENABLED=true\n' >> "${ENV_VARS_FILE}"
    chmod 600 "${ENV_VARS_FILE}"
    bashio::log.info "Screenshot tool enabled (Chromium headless for visual verification)"
else
    bashio::log.info "Screenshot tool disabled (enable in Configuration tab to use visual verification)"
fi

# ==============================================================================
# Background service discovery (Zigbee2MQTT + ESPHome)
# Discovers Z2M_URL/Z2M_MQTT_TOPIC and HAB_ESPHOME_URL/HAB_ESPHOME_SESSION for
# shell users. The MCP server does its own runtime discovery, so this runs
# fully detached — boot never waits on network discovery. Results land in
# /data/.env_vars_discovered, sourced alongside /data/.env_vars when present.
# ==============================================================================

rm -f /data/.env_vars_discovered

if [ -n "${ACCESS_TOKEN}" ] || [ "${DISCOVER_Z2M_FLAG}" = "true" ]; then
    bashio::log.info "Starting background discovery (Zigbee2MQTT/ESPHome)..."
    # setsid detaches the process into its own session so it survives the
    # oneshot's exit; output goes to a log file for debugging
    HA_ACCESS_TOKEN="${ACCESS_TOKEN}" DISCOVER_Z2M="${DISCOVER_Z2M_FLAG}" \
        setsid node /usr/local/bin/discover-services.js \
        >/tmp/discover-services.log 2>&1 </dev/null &
fi

if [ -z "${ACCESS_TOKEN}" ]; then
    bashio::log.warning "No access token configured — ESPHome tools will not work"
    bashio::log.warning "Set a Long-Lived Access Token in the add-on Configuration tab"
fi

# ==============================================================================
# CPU Capability Detection - record diagnostics for OpenCode's runtime selector
# ==============================================================================

warn_baseline_mode() {
    bashio::log.warning "OpenCode x64 baseline mode may be used because AVX2 is not visible to the container."
    bashio::log.warning "If this add-on runs in a VM on an AVX2-capable host, enable host CPU passthrough; generic QEMU/KVM CPU models can hide AVX2."
    bashio::log.warning "Known upstream baseline OOM issue: https://github.com/anomalyco/opencode/issues/20988"
}

detect_cpu_capabilities() {
    local cpu_mode_config="${CPU_MODE_CONFIG:-auto}"
    local machine
    local cpu_flags=""
    local has_avx2=false
    local has_avx=false

    machine=$(uname -m)

    if [ -f /proc/cpuinfo ]; then
        cpu_flags=$(awk -F': ' '/^flags/ {print $2; exit}' /proc/cpuinfo)
    fi

    if echo "${cpu_flags}" | grep -q '\bavx2\b'; then
        has_avx2=true
    fi

    if echo "${cpu_flags}" | grep -q '\bavx\b'; then
        has_avx=true
    fi

    if [ "${machine}" = "aarch64" ] || [ "${machine}" = "arm64" ]; then
        echo "regular" > /data/.cpu_mode
        if [ "${cpu_mode_config}" = "baseline" ]; then
            bashio::log.warning "CPU mode baseline was requested, but ARM64 has no OpenCode baseline package; using regular binary"
        else
            bashio::log.info "ARM64 architecture detected - using regular OpenCode binary"
        fi
        return
    fi

    if [ "${cpu_mode_config}" = "baseline" ]; then
        echo "baseline" > /data/.cpu_mode
        bashio::log.warning "CPU mode forced to baseline by configuration"
        warn_baseline_mode
        return
    elif [ "${cpu_mode_config}" = "regular" ]; then
        echo "regular" > /data/.cpu_mode
        if [ "${machine}" = "x86_64" ] && [ "${has_avx2}" != "true" ]; then
            bashio::log.warning "CPU mode forced to regular, but AVX2 is not visible; OpenCode may fail with an illegal instruction"
        else
            bashio::log.info "CPU mode forced to regular by configuration"
        fi
        return
    fi

    if [ "${has_avx2}" = "true" ]; then
        echo "regular" > /data/.cpu_mode
        bashio::log.info "CPU supports AVX2 - OpenCode regular binary will be selected"
    elif [ "${has_avx}" = "true" ]; then
        echo "baseline" > /data/.cpu_mode
        bashio::log.warning "CPU has AVX but not AVX2 - OpenCode baseline binary will be selected"
        warn_baseline_mode
    else
        echo "baseline" > /data/.cpu_mode
        bashio::log.warning "CPU lacks AVX support - OpenCode baseline binary will be selected"
        warn_baseline_mode
    fi
}

detect_cpu_capabilities

# ==============================================================================
# Install/verify OpenCode through the upstream opencode-ai package
# ==============================================================================

opencode_package_version() {
    local package_dir="$1"
    if [ -f "${package_dir}/package.json" ]; then
        node -e "console.log(require('${package_dir}/package.json').version)" 2>/dev/null || echo "unknown"
    else
        echo "not-installed"
    fi
}

select_opencode_package_binary() {
    local package_dir="$1"
    local mode="$2"
    local machine
    local source_binary=""
    local target_binary="${package_dir}/bin/opencode.exe"

    machine=$(uname -m)

    case "${machine}" in
        x86_64)
            if [ "${mode}" = "baseline" ]; then
                source_binary="${package_dir}/node_modules/opencode-linux-x64-baseline/bin/opencode"
            else
                source_binary="${package_dir}/node_modules/opencode-linux-x64/bin/opencode"
            fi
            ;;
        aarch64|arm64)
            source_binary="${package_dir}/node_modules/opencode-linux-arm64/bin/opencode"
            mode="regular"
            ;;
        *)
            bashio::log.warning "Unknown architecture $(uname -m); leaving OpenCode package binary unchanged"
            return 0
            ;;
    esac

    if [ ! -x "${source_binary}" ]; then
        bashio::log.warning "OpenCode ${mode} binary not found at ${source_binary}; leaving package binary unchanged"
        return 1
    fi

    mkdir -p "$(dirname "${target_binary}")"
    rm -f "${target_binary}"
    if ! ln "${source_binary}" "${target_binary}" 2>/dev/null; then
        cp "${source_binary}" "${target_binary}"
    fi
    chmod +x "${target_binary}"
    bashio::log.info "OpenCode package binary selected: ${mode} (${source_binary})"
}

setup_opencode_runtime() {
    local cpu_mode
    local bundled_package="/usr/local/lib/node_modules/opencode-ai"
    local runtime_package="${NPM_CONFIG_PREFIX}/lib/node_modules/opencode-ai"
    local bundled_version
    local runtime_version
    local runtime_available=false

    cpu_mode=$(cat /data/.cpu_mode 2>/dev/null || echo "regular")
    bundled_version=$(opencode_package_version "${bundled_package}")
    runtime_version=$(opencode_package_version "${runtime_package}")

    bashio::log.info "Bundled OpenCode version: ${bundled_version}"

    if [ "${OPENCODE_UPDATE_POLICY}" = "latest" ]; then
        if [ "${runtime_version}" != "not-installed" ]; then
            bashio::log.info "Persistent OpenCode version before update: ${runtime_version}"
        fi

        bashio::log.info "Updating persistent OpenCode install: npm install -g opencode-ai@latest"
        if timeout 300 npm install -g opencode-ai@latest --loglevel=error >/tmp/opencode-npm-install.log 2>&1; then
            runtime_version=$(opencode_package_version "${runtime_package}")
            bashio::log.info "Persistent OpenCode version after update: ${runtime_version}"
        else
            bashio::log.warning "OpenCode runtime update failed; continuing with existing runtime install or bundled fallback"
            bashio::log.warning "See /tmp/opencode-npm-install.log inside the container for npm details"
        fi

        if [ -x "${runtime_package}/bin/opencode.exe" ]; then
            select_opencode_package_binary "${runtime_package}" "${cpu_mode}" || true
            runtime_available=true
        else
            bashio::log.warning "No persistent OpenCode binary found under ${NPM_CONFIG_PREFIX}; using bundled OpenCode"
        fi
    fi

    if [ "${OPENCODE_UPDATE_POLICY}" = "bundled" ] || [ "${runtime_available}" != "true" ]; then
        select_opencode_package_binary "${bundled_package}" "${cpu_mode}" || true
    fi

    local effective_bin
    local effective_version
    effective_bin=$(command -v opencode 2>/dev/null || echo "not-found")
    effective_version=$(opencode --version 2>/dev/null || echo "unknown")
    printf '%s\n' "${effective_bin}" > /data/.opencode_bin
    printf '%s\n' "${effective_version}" > /data/.opencode_version
    bashio::log.info "Effective OpenCode binary: ${effective_bin}"
    bashio::log.info "Effective OpenCode version: ${effective_version}"
}

setup_opencode_runtime

# ==============================================================================
# Verify hab and zigporter CLIs are available
# CLI versions only change with an addon update, so they're cached in the
# help stamp alongside the addon version — a matching stamp skips the version
# spawns AND the AGENTS.md help re-injection below.
# ==============================================================================

HELP_STAMP_FILE="/data/.help_stamp"
STAMP_ADDON=""
STAMP_HAB=""
STAMP_ZIGPORTER=""
if [ -f "${HELP_STAMP_FILE}" ]; then
    IFS=':' read -r STAMP_ADDON STAMP_HAB STAMP_ZIGPORTER < "${HELP_STAMP_FILE}" || true
fi
HELP_STAMP_FRESH=false
if [ "${STAMP_ADDON}" = "${ADDON_VERSION}" ] && [ -n "${STAMP_HAB}" ]; then
    HELP_STAMP_FRESH=true
fi

if command -v hab &>/dev/null; then
    if [ "${HELP_STAMP_FRESH}" = "true" ]; then
        HAB_VERSION="${STAMP_HAB}"
    else
        HAB_VERSION=$(hab version 2>/dev/null | grep -oP '[\d.]+' | head -1 || echo "unknown")
    fi
    bashio::log.info "hab CLI available (v${HAB_VERSION}) - pre-authenticated via Supervisor"
else
    bashio::log.warning "hab CLI not found - some admin features will be unavailable"
fi

if command -v zigporter &>/dev/null; then
    if [ "${HELP_STAMP_FRESH}" = "true" ]; then
        ZIGPORTER_VERSION="${STAMP_ZIGPORTER}"
    else
        ZIGPORTER_VERSION=$(zigporter --version 2>/dev/null | grep -oP '[\d.]+' | head -1 || echo "unknown")
    fi
    bashio::log.info "zigporter CLI available (v${ZIGPORTER_VERSION}) - Zigbee rename, inspect, mesh tools"
else
    bashio::log.warning "zigporter CLI not found - Zigbee management features will be unavailable"
fi

# ==============================================================================
# Deploy AGENTS.md to Home Assistant config directory
# On first install: copy the full file
# On update: if user hasn't customized it, refresh to get latest instructions
# A fresh help stamp means the deployed copy already has current help injected,
# so both the refresh-copy and the injection passes are skipped.
# ==============================================================================

AGENTS_REFRESHED=false

if [ ! -f "/homeassistant/AGENTS.md" ]; then
    cp /opt/ha-mcp-server/AGENTS.md /homeassistant/AGENTS.md
    AGENTS_REFRESHED=true
    bashio::log.info "Deployed default AGENTS.md to /homeassistant/"
    bashio::log.info "You can customize AI instructions by editing AGENTS.md"
elif [ "${HELP_STAMP_FRESH}" = "true" ]; then
    bashio::log.info "AGENTS.md is current (addon version unchanged) - skipping refresh"
else
    # Check if the user has customized AGENTS.md by comparing a known marker
    # If it still contains our marker comment, it's safe to update
    if grep -q "# Home Assistant OpenCode Rules" /homeassistant/AGENTS.md 2>/dev/null; then
        cp /opt/ha-mcp-server/AGENTS.md /homeassistant/AGENTS.md
        AGENTS_REFRESHED=true
        bashio::log.info "Updated AGENTS.md with latest AI instructions"
    else
        bashio::log.info "AGENTS.md has been customized by user - skipping update"
    fi
fi

# ==============================================================================
# Inject live hab help output into AGENTS.md
# Replaces the content between HAB_LIVE_HELP markers with current `hab --help`
# output so the AI always sees the exact commands available in the installed
# hab version — regardless of what was documented when the addon was built.
# Only runs when AGENTS.md was (re)deployed this boot.
# ==============================================================================

if [ "${AGENTS_REFRESHED}" = "true" ] && command -v hab &>/dev/null && [ -f "/homeassistant/AGENTS.md" ]; then
    if grep -q "<!-- HAB_LIVE_HELP_START -->" /homeassistant/AGENTS.md 2>/dev/null; then
        HAB_HELP_OUTPUT=$(hab --help 2>/dev/null || echo "")
        if [ -n "${HAB_HELP_OUTPUT}" ]; then
            printf '%s\n' "${HAB_HELP_OUTPUT}" > /tmp/hab_help.txt
            awk '
                /<!-- HAB_LIVE_HELP_START -->/ {
                    print
                    print "```"
                    while ((getline line < "/tmp/hab_help.txt") > 0) print line
                    print "```"
                    skip=1
                    next
                }
                /<!-- HAB_LIVE_HELP_END -->/ {
                    skip=0
                    print
                    next
                }
                !skip { print }
            ' /homeassistant/AGENTS.md > /tmp/agents_tmp \
                && mv /tmp/agents_tmp /homeassistant/AGENTS.md
            rm -f /tmp/hab_help.txt
            bashio::log.info "Injected live hab help (v${HAB_VERSION}) into AGENTS.md"
        fi
    fi
fi

# ==============================================================================
# Inject live zigporter help output into AGENTS.md
# Same pattern as hab — replaces content between ZIGPORTER_LIVE_HELP markers
# so the AI always sees the exact commands available in the installed version.
# ==============================================================================

if [ "${AGENTS_REFRESHED}" = "true" ] && command -v zigporter &>/dev/null && [ -f "/homeassistant/AGENTS.md" ]; then
    if grep -q "<!-- ZIGPORTER_LIVE_HELP_START -->" /homeassistant/AGENTS.md 2>/dev/null; then
        ZIGPORTER_HELP_OUTPUT=$(zigporter --help 2>/dev/null || echo "")
        if [ -n "${ZIGPORTER_HELP_OUTPUT}" ]; then
            printf '%s\n' "${ZIGPORTER_HELP_OUTPUT}" > /tmp/zigporter_help.txt
            awk '
                /<!-- ZIGPORTER_LIVE_HELP_START -->/ {
                    print
                    print "```"
                    while ((getline line < "/tmp/zigporter_help.txt") > 0) print line
                    print "```"
                    skip=1
                    next
                }
                /<!-- ZIGPORTER_LIVE_HELP_END -->/ {
                    skip=0
                    print
                    next
                }
                !skip { print }
            ' /homeassistant/AGENTS.md > /tmp/agents_tmp \
                && mv /tmp/agents_tmp /homeassistant/AGENTS.md
            rm -f /tmp/zigporter_help.txt
            bashio::log.info "Injected live zigporter help (v${ZIGPORTER_VERSION}) into AGENTS.md"
        fi
    fi
fi

# Record the stamp so unchanged boots skip the version spawns and re-injection
if [ "${HELP_STAMP_FRESH}" != "true" ]; then
    printf '%s:%s:%s\n' "${ADDON_VERSION}" "${HAB_VERSION:-unknown}" "${ZIGPORTER_VERSION:-unknown}" > "${HELP_STAMP_FILE}"
fi

# ==============================================================================
# Deploy Prettier config for HA YAML formatting (first install only)
# Prettier auto-formats YAML files written by OpenCode to follow HA conventions
# Users can customize .prettierrc.yaml to adjust formatting preferences
# ==============================================================================

if [ ! -f "/homeassistant/.prettierrc.yaml" ]; then
    cp /opt/ha-mcp-server/.prettierrc.yaml /homeassistant/.prettierrc.yaml
    bashio::log.info "Deployed default .prettierrc.yaml for HA YAML formatting"
fi

# ==============================================================================
# Generate OpenCode configuration file
# ==============================================================================

MCP_BOOL=$([ "${MCP_ENABLED}" = "true" ] && echo "true" || echo "false")
NATIVE_HA_MCP_BOOL=$([ "${NATIVE_HA_MCP_ENABLED}" = "true" ] && echo "true" || echo "false")
LSP_DISABLED=$([ "${LSP_ENABLED}" = "true" ] && echo "false" || echo "true")
PPQ_PROVIDER_ENABLED=$([ "${PPQ_PRIVATE_ENABLED}" = "true" ] && [ "${PPQ_API_KEY_CONFIGURED}" = "true" ] && echo "true" || echo "false")

jq --arg native_ha_mcp_api_id "${NATIVE_HA_MCP_API_ID}" --argjson mcp "${MCP_BOOL}" --argjson native_ha_mcp "${NATIVE_HA_MCP_BOOL}" --argjson lsp_disabled "${LSP_DISABLED}" --argjson ppq "${PPQ_PROVIDER_ENABLED}" '
    .mcp.homeassistant.enabled = $mcp |
    .mcp.homeassistant.environment.HA_NATIVE_MCP_API_ID = $native_ha_mcp_api_id |
    .mcp.homeassistant_native.enabled = ($mcp and $native_ha_mcp) |
    .mcp.homeassistant_native.command = ["node", "/opt/ha-mcp-server/ha-native-mcp-proxy.js", $native_ha_mcp_api_id] |
    .mcp.homeassistant_native.environment.HA_NATIVE_MCP_API_ID = $native_ha_mcp_api_id |
    if $lsp_disabled then .lsp["ha-yaml"].disabled = true else del(.lsp["ha-yaml"].disabled) end |
    if $ppq then
        .provider = (.provider // {}) |
        .provider["ppq-private"] = {
            "npm": "@ai-sdk/openai-compatible",
            "name": "PPQ Private (TEE)",
            "options": {
                "apiKey": "unused",
                "baseURL": "http://127.0.0.1:8787/v1",
                "timeout": 600000,
                "chunkTimeout": 60000
            },
            "models": {
                "private/kimi-k2-5": {
                    "name": "Kimi K2.5 (Private)",
                    "limit": { "context": 262144, "output": 8192 }
                },
                "private/deepseek-r1-0528": {
                    "name": "DeepSeek R1 (Private)",
                    "reasoning": true,
                    "limit": { "context": 131072, "output": 8192 }
                },
                "private/gpt-oss-120b": {
                    "name": "GPT-OSS 120B (Private)",
                    "limit": { "context": 131072, "output": 8192 }
                },
                "private/llama3-3-70b": {
                    "name": "Llama 3.3 70B (Private)",
                    "limit": { "context": 131072, "output": 8192 }
                },
                "private/qwen3-vl-30b": {
                    "name": "Qwen3-VL 30B (Private)",
                    "attachment": true,
                    "limit": { "context": 262144, "output": 8192 }
                }
            }
        }
    else . end
' /opt/ha-mcp-server/opencode-ha.json > /data/.config/opencode/opencode.json

bashio::log.info "OpenCode configuration generated successfully"

# ==============================================================================
# Inject custom OpenCode config.json (optional, for advanced users)
# This allows power users to provide custom OpenCode configuration as a JSON
# string via the add-on config UI. It is written to config.json which OpenCode
# merges with opencode.json (our MCP/LSP config) at startup.
# See https://opencode.ai/docs/config for the full schema.
# ==============================================================================

OPTIONS_FILE="/data/options.json"
CONFIG_TARGET="/data/.config/opencode/config.json"

if [ -f "${OPTIONS_FILE}" ]; then
    OPENCODE_CONFIG_JSON=$(jq -r '.opencode_config // empty' "${OPTIONS_FILE}")
    if [ -n "${OPENCODE_CONFIG_JSON}" ]; then
        # Validate that the provided string is valid JSON
        if ! printf '%s' "${OPENCODE_CONFIG_JSON}" | jq -e . >/dev/null 2>&1; then
            bashio::log.error "Invalid JSON in opencode_config option. Skipping custom config."
            bashio::log.error "Please check your JSON syntax in the Configuration tab."
            # Remove stale config.json so a previously valid config doesn't persist
            rm -f "${CONFIG_TARGET}"
        else
            printf '%s' "${OPENCODE_CONFIG_JSON}" > "${CONFIG_TARGET}"
            bashio::log.info "Custom OpenCode config.json written from add-on configuration"
        fi
    else
        # No custom config provided - remove any stale config.json from a previous run
        rm -f "${CONFIG_TARGET}"
    fi
fi

bashio::log.info "OpenCode initialization complete"
